{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "create-react-app",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "framework": "django",
      "excludeFiles": [
        ".venv/**",
        "backend/.venv/**",
        "**/__pycache__/**",
        "**/*.pyc"
      ],
      "routePrefix": "/_/backend"
    }
  }
}
